{
  "name": "trip-tactician-pro",
  "version": "2.1.0",
  "description": "AI-powered trip planner with real-time data and comprehensive itineraries",
  "main": "index.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:unit": "vitest run",
    "eject": "react-scripts eject",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "npm --prefix client run dev",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "security-check": "npm audit --audit-level=moderate",
    "setup-ollama": "ollama pull llama3.1:8b",
    "start-ollama": "ollama serve",
    "test-ollama": "node test-ollama.js",
    "dev-full": "concurrently \"ollama serve\" \"npm run server\" \"npm run client\"",
    "build-airports": "node scripts/generate-airports-json.js"
  },
