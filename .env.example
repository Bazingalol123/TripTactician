# Server
NODE_ENV=development
PORT=5000

# MongoDB — get your URI from https://cloud.mongodb.com/
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT — must be at least 32 chars, generate with: openssl rand -hex 32
JWT_SECRET=replace_this_with_a_long_random_string_at_least_32_chars

# LLM provider — 'openai' for production, 'ollama' for local dev
LLM_PROVIDER=openai

# OpenAI — get key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Ollama (local only) — run: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Google Places — get key from https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=

# Viator affiliate — optional, for experience booking links
VIATOR_AFFILIATE_ID=
VIATOR_AFFILIATE_SECRET=

# GetYourGuide affiliate — optional
GYG_AFFILIATE_ID=

# Booking.com affiliate — optional, for hotel booking links
BOOKING_AFFILIATE_ID=

# Email — get key from https://resend.com/
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# Frontend URL (used in email links)
CLIENT_URL=http://localhost:3000

# LLM rate limiting — max AI generation requests per user per hour
LLM_RATE_LIMIT_MAX=5

# Logging level
LOG_LEVEL=info
